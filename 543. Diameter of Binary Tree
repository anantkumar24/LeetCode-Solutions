class Solution {
public:
    int ans=0;
    int Height(TreeNode* root) {
        if (!root)
            return 0;
        int leftht = Height(root->left);
        int rightht = Height(root->right);
        ans=max(ans,leftht+rightht);
        return max(leftht, rightht) + 1;
        
    }
    int diameterOfBinaryTree(TreeNode* root) {
        if (root == NULL)
            return 0;
            Height(root);
            return ans;
        
    }
};
